# Copy this to .env and fill in values. Never commit .env.

# Madeye — PocketFM's OpenAI-compatible LLM gateway.
# Used by both main.py (backend proxy) and verify_ls.py --llm (batch engine).
MADEYE_API_KEY=...                            # Madeye API key (sent as Bearer token)
MADEYE_BASE_URL=https://madeye.internal.pocketfm.org
MADEYE_MODEL=claude-opus-4-8                  # optional, this is the default
MADEYE_USER_EMAIL=your.name@pocketfm.com      # REQUIRED — Madeye needs metadata.user_email

# A random secret string — put the same value in Apps Script Properties as PROXY_SECRET
PROXY_SECRET=change-me-to-a-long-random-string

# canon.pocketfm.ai __session cookie (refresh when it expires, 24hr TTL)
CANON_SESSION=eyJhbGci...

PORT=8000
