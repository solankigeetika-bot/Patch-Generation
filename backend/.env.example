# Copy this to .env and fill in values. Never commit .env.

# Anthropic API (for verify_ls.py --llm, Layer 2 LLM verification)
ANTHROPIC_API_KEY=sk-ant-...                  # Anthropic API key
ANTHROPIC_MODEL=claude-opus-4-8               # optional, this is the default

# Argus (PocketFM internal LLM proxy — used by main.py FastAPI backend)
ARGUS_API_KEY=eyJ...                          # Argus token, or sk-... API key
ARGUS_BASE_URL=https://argus.pocketfm.org/api
ARGUS_MODEL=claude-opus-4.8

# A random secret string — put the same value in Apps Script Properties as PROXY_SECRET
PROXY_SECRET=change-me-to-a-long-random-string

# canon.pocketfm.ai __session cookie (refresh when it expires, 24hr TTL)
CANON_SESSION=eyJhbGci...

PORT=8000
